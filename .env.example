# ── LLM Provider Keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Model Selection ────────────────────────────────────────────────────────────
# Model under test (what your product uses)
TEST_MODEL=claude-haiku-4-5-20251001
# Judge model — MUST differ from test model to avoid self-scoring bias
JUDGE_MODEL=gpt-4o-mini

# ── Local Ollama (optional) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./regression_suite.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/regression_suite

# ── Runner Behaviour ───────────────────────────────────────────────────────────
RUN_COUNT=3                     # Runs per test case (averaged to reduce variance)
REGRESSION_DELTA_THRESHOLD=0.05 # Score drop that constitutes a regression
FLAKINESS_STD_THRESHOLD=0.05    # Std-dev above which a test is flagged flaky
MAX_CONCURRENT_WORKERS=10       # Async concurrency for LLM calls

# ── Paths ──────────────────────────────────────────────────────────────────────
TESTS_DIR=tests
PROMPTS_DIR=prompts

# ── Notifications ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── GitHub CI ─────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=org/repo
